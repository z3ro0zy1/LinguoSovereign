DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=0
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
NEXTAUTH_SECRET=replace-with-a-long-random-secret #注意这里
NEXTAUTH_URL=http://localhost:3000

# OpenAI-compatible provider examples:
# OpenAI official: leave OPENAI_BASE_URL empty and use an OpenAI model name.
# Moonshot / Kimi: set OPENAI_BASE_URL=https://api.moonshot.cn/v1
# Zhipu / GLM4: set GLM_BASE_URL to the provider's OpenAI-compatible endpoint.
OPENAI_API_KEY=
OPENAI_MODEL=moonshot-v1-8k
OPENAI_BASE_URL=
OPENAI_SPEAKING_EVAL_MODEL=kimi-latest
OPENAI_READING_ANALYSIS_MODEL=

GLM_API_KEY=
GLM_BASE_URL=
GLM_MODEL=
GLM_SPEAKING_EVAL_MODEL=
GLM_READING_ANALYSIS_MODEL=
# GLM's tts model can be used for Live Speaking

# Gemini speaking workflow
GEMINI_API_KEY=
GEMINI_SPEAKING_MODEL=gemini-3.1-flash-live-preview # This is used for live speaking mode.
GEMINI_SPEAKING_EVAL_MODEL=gemini-3.1-flash-lite-preview
# Used by speaking transcript scoring when you want it to go through Gemini Flash-Lite.
